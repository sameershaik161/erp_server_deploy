# Production Backend URLs - AWS Deployment
# Replace these with your actual AWS backend URL after deployment
VITE_API_BASE_URL=https://your-backend.execute-api.region.amazonaws.com/api
VITE_BACKEND_URL=https://your-backend.execute-api.region.amazonaws.com

# Alternative: If using EC2 with domain
# VITE_API_BASE_URL=https://api.yourdomain.com/api
# VITE_BACKEND_URL=https://api.yourdomain.com

# Alternative: If using Elastic Beanstalk
# VITE_API_BASE_URL=http://your-app.elasticbeanstalk.com/api
# VITE_BACKEND_URL=http://your-app.elasticbeanstalk.com
